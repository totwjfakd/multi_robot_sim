<?xml version="1.0"?>
<sdf version="1.6">
    <model name="X1">
        <static>0</static>
        <link name="base_link">
            <inertial>
                <pose frame="">0.0 0.0 0.062 0 0 0</pose>
                <mass>46.034</mass>
                <inertia>
                    <ixx>0.613201</ixx><ixy>-0.0236401</ixy><ixz>-0.1197</ixz>
                    <iyy>1.7496</iyy><iyz>-0.00154411</iyz><izz>2.0406</izz>
                </inertia>
            </inertial>
            <collision name="base_link_collision">
                <pose frame="">0 0 0.12 0 0 0</pose>
                <geometry><box><size>0.9874 0.5709 0.05</size></box></geometry>
            </collision>
            <collision name="base_link_collision_bottom">
                <pose frame="">0 0 0.046 0 0 0</pose>
                <geometry><box><size>0.80 0.5709 0.095</size></box></geometry>
            </collision>
            <collision name="base_link_collision_1">
                <pose frame="">0 0 0.185625 0 0 0</pose>
                <geometry><box><size>0.78992 0.5709 0.12375</size></box></geometry>
            </collision>
            <collision name="top_plate_collision">
                <pose frame="">0.0812 0 0.245 0 0 0</pose>
                <geometry><box><size>0.32 0.41 0.09</size></box></geometry>
            </collision>
            <visual name="base_link_visual">
                <pose frame="">0 0 0 0 0 -3.14159</pose>
                <geometry><mesh><uri>model://X1_Config_5/meshes/chassis.dae</uri></mesh></geometry>
            </visual>
            <visual name="top_plate_visual">
                <pose frame="">0.0812 0 0.245 0 0 0</pose>
                <geometry><mesh><uri>model://X1_Config_5/meshes/top_plate.dae</uri></mesh></geometry>
            </visual>

            <!-- Front LiDAR (x1_robot.urdf: 0.5 0.0 0.2) -->
            <visual name="lidar_front_visual">
                <pose>0.5 0.0 0.2 0 0 0</pose>
                <geometry><cylinder><radius>0.06</radius><length>0.08</length></cylinder></geometry>
            </visual>
            <sensor name="gpu_lidar" type="gpu_lidar">
                <pose>0.5 0.0 0.15 0 0 0</pose>
                <update_rate>10</update_rate>
                <frame_id>slam_1/lidar_link</frame_id>
                <ray>
                    <scan>
                        <horizontal>
                            <samples>720</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5708</min_angle>
                            <max_angle>1.5708</max_angle>
                        </horizontal>
                        <vertical>
                            <samples>1</samples><resolution>0.01</resolution>
                            <min_angle>0</min_angle><max_angle>0</max_angle>
                        </vertical>
                    </scan>
                    <range><min>0.08</min><max>20.0</max><resolution>0.01</resolution></range>
                    <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
                </ray>
                <always_on>1</always_on>
                <visualize>true</visualize>
            </sensor>

            <!-- Rear LiDAR (x1_robot.urdf: -0.5 0.0 0.2, yaw=π) -->
            <visual name="lidar_rear_visual">
                <pose>-0.5 0.0 0.2 0 0 0</pose>
                <geometry><cylinder><radius>0.06</radius><length>0.08</length></cylinder></geometry>
            </visual>
            <sensor name="gpu_lidar_rear" type="gpu_lidar">
                <pose>-0.5 0.0 0.15 0 0 3.14159</pose>
                <update_rate>10</update_rate>
                <frame_id>slam_1/lidar_rear_link</frame_id>
                <ray>
                    <scan>
                        <horizontal>
                            <samples>720</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5708</min_angle>
                            <max_angle>1.5708</max_angle>
                        </horizontal>
                        <vertical>
                            <samples>1</samples><resolution>0.01</resolution>
                            <min_angle>0</min_angle><max_angle>0</max_angle>
                        </vertical>
                    </scan>
                    <range><min>0.08</min><max>20.0</max><resolution>0.01</resolution></range>
                    <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
                </ray>
                <always_on>1</always_on>
                <visualize>true</visualize>
            </sensor>
        </link>

        <link name="mid_left_wheel">
            <pose frame="">0.0 0.2854 0.03282 0 0 0</pose>
            <inertial><mass>2.637</mass>
                <inertia><ixx>0.02467</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.04411</iyy><iyz>0</iyz><izz>0.02467</izz></inertia>
            </inertial>
            <collision name="collision">
                <pose frame="">0 0 0 -1.5707963267948966 0 0</pose>
                <geometry><cylinder><length>0.1143</length><radius>0.1651</radius></cylinder></geometry>
                <surface><friction><ode><mu>0.5</mu><mu2>1</mu2><slip1>0.00062</slip1><slip2>0</slip2><fdir1>0 0 1</fdir1></ode></friction></surface>
            </collision>
            <visual name="visual"><geometry><mesh><uri>model://X1_Config_5/meshes/wheel.dae</uri></mesh></geometry></visual>
        </link>
        <joint name="mid_left_wheel_joint" type="revolute">
            <parent>base_link</parent><child>mid_left_wheel</child>
            <axis><xyz>0 1 0</xyz><limit><lower>-1.79769e+308</lower><upper>+1.79769e+308</upper></limit></axis>
        </joint>

