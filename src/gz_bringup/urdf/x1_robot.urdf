<?xml version="1.0"?>
<robot name="x1_robot">

  <!-- Base link (main chassis) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.9874 0.5709 0.05"/>
      </geometry>
      <material name="chassis_dark">
        <color rgba="0.18 0.18 0.18 1.0"/>
      </material>
    </visual>
    <visual name="chassis_bottom">
      <origin xyz="0 0 0.046" rpy="0 0 0"/>
      <geometry>
        <box size="0.80 0.5709 0.095"/>
      </geometry>
      <material name="chassis_mid">
        <color rgba="0.24 0.24 0.24 1.0"/>
      </material>
    </visual>
    <visual name="chassis_upper">
      <origin xyz="0 0 0.185625" rpy="0 0 0"/>
      <geometry>
        <box size="0.78992 0.5709 0.12375"/>
      </geometry>
      <material name="chassis_light">
        <color rgba="0.32 0.32 0.32 1.0"/>
      </material>
    </visual>
    <visual name="top_plate">
      <origin xyz="0.0812 0 0.245" rpy="0 0 0"/>
      <geometry>
        <box size="0.32 0.41 0.09"/>
      </geometry>
      <material name="top_blue">
        <color rgba="0.05 0.25 0.90 1.0"/>
      </material>
    </visual>
  </link>

  <!-- LiDAR sensor -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.06" length="0.08"/>
      </geometry>
      <material name="lidar_red">
        <color rgba="0.90 0.10 0.10 1.0"/>
      </material>
    </visual>
  </link>

  <!-- LiDAR joint (based on SDF: relative_to="lidar_frame" 0 0 0.4) -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.5 0.0 0.2" rpy="0 0 0"/>
  </joint>

  <!-- Rear LiDAR sensor frame -->
  <link name="lidar_rear_link">
    <visual>
      <geometry>
        <cylinder radius="0.06" length="0.08"/>
      </geometry>
      <material name="lidar_rear_orange">
        <color rgba="0.95 0.45 0.10 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_rear_link"/>
    <origin xyz="-0.5 0.0 0.2" rpy="0 0 3.14159"/>
  </joint>

  <!-- IMU sensor -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.015"/>
      </geometry>
      <material name="imu_green">
        <color rgba="0.10 0.80 0.20 1.0"/>
      </material>
    </visual>
  </link>

  <!-- IMU joint (based on SDF inertial frame) -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.062" rpy="0 0 0"/>
  </joint>

</robot>
